.guide-page {
  min-height: 100vh;
  background: #f5efe7;
  position: relative;
  overflow: hidden;
}

.component-viewport {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  height: 50vh;
  z-index: 80;
  transform: translateY(-106%);
  opacity: 0;
  pointer-events: none;
  transition: transform 360ms cubic-bezier(0.2, 0.72, 0.2, 1), opacity 220ms ease;
}

.component-viewport-active {
  transform: translateY(0);
  opacity: 1;
  pointer-events: auto;
}

.component-shell {
  height: 100%;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 20rpx) 24rpx 18rpx;
  background:
    radial-gradient(circle at 16% 8%, rgba(255, 255, 255, 0.4), transparent 34%),
    linear-gradient(180deg, rgba(244, 232, 218, 0.98), rgba(236, 219, 198, 0.95));
  border-bottom-left-radius: 28rpx;
  border-bottom-right-radius: 28rpx;
  border: 2rpx solid rgba(175, 123, 79, 0.24);
  box-shadow: 0 16rpx 40rpx rgba(81, 52, 27, 0.14);
}

.component-head {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}

.component-title {
  font-size: 30rpx;
  color: #3b2a1d;
  font-weight: 600;
}

.component-body {
  height: calc(100% - 52rpx);
}

.component-info {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.component-desc {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6b4d33;
}

.dialog-viewport {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  z-index: 60;
  transition:
    top 360ms cubic-bezier(0.2, 0.72, 0.2, 1),
    height 360ms cubic-bezier(0.2, 0.72, 0.2, 1),
    border-radius 320ms ease,
    box-shadow 320ms ease;
}

.dialog-viewport-split {
  top: 50vh;
  height: 50vh;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  box-shadow: 0 -12rpx 34rpx rgba(52, 33, 17, 0.2);
}

.split-divider {
  position: absolute;
  left: 50%;
  top: 0;
  width: 260rpx;
  height: 56rpx;
  transform: translate(-50%, -50%);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 95;
}

.split-divider-bar {
  width: 200rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(70, 50, 34, 0.5);
  box-shadow: 0 2rpx 6rpx rgba(255, 255, 255, 0.45);
}

.dialog-page {
  min-height: 100vh;
  background: #f5efe7;
  position: relative;
  overflow: hidden;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.status-space {
  height: 104rpx;
}

.topbar {
  height: 92rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.title-wrap {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  text-align: center;
  pointer-events: none;
}

.main-title {
  font-size: 40rpx;
  font-weight: 400;
  color: #281d13;
  line-height: 1.2;
}

.sub-title {
  display: none;
}

.center-stage {
  height: calc(100vh - 500rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #4a3628;
}

.dialog-viewport-split .center-stage {
  height: calc(50vh - 332rpx);
  min-height: 120rpx;
}

.welcome-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #2d2015;
}

.chat-dock {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 60;
  padding: 16rpx 16rpx calc(env(safe-area-inset-bottom) + 20rpx);
  background: linear-gradient(
    to top,
    rgba(245, 239, 231, 1) 20%,
    rgba(245, 239, 231, 0.9) 72%,
    rgba(245, 239, 231, 0)
  );
  transform: translateY(0);
  transition: transform 360ms cubic-bezier(0.2, 0.72, 0.2, 1);
}

.chat-dock-split {
  transform: translateY(-120rpx);
}

.chip-row-placeholder {
  height: 72rpx;
}

.input-bar {
  margin-top: 12rpx;
  min-height: 94rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid rgba(150, 111, 76, 0.15);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 22rpx rgba(95, 64, 38, 0.14);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  gap: 16rpx;
}

.left-icons,
.right-icons {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder {
  flex: 1;
  color: #9e836a;
  font-size: 38rpx;
}

.ico {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  box-sizing: border-box;
}

.ico-menu {
  background:
    linear-gradient(#2f241a, #2f241a) center 8rpx / 34rpx 4rpx no-repeat,
    linear-gradient(#2f241a, #2f241a) center 20rpx / 34rpx 4rpx no-repeat,
    linear-gradient(#2f241a, #2f241a) center 32rpx / 34rpx 4rpx no-repeat;
}

.ico-camera {
  border: 3rpx solid #25180f;
  border-radius: 10rpx;
}

.ico-camera::before {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  width: 14rpx;
  height: 14rpx;
  border: 3rpx solid #25180f;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.ico-camera::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: -6rpx;
  width: 14rpx;
  height: 8rpx;
  border: 3rpx solid #25180f;
  border-bottom: 0;
  border-top-left-radius: 6rpx;
  border-top-right-radius: 6rpx;
  background: #f5efe7;
}

.ico-mic {
  width: 24rpx;
  height: 32rpx;
  border: 3rpx solid #25180f;
  border-radius: 14rpx;
  border-bottom-left-radius: 12rpx;
  border-bottom-right-radius: 12rpx;
  margin-top: 2rpx;
}

.ico-mic::before {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -12rpx;
  width: 22rpx;
  height: 12rpx;
  border: 3rpx solid #25180f;
  border-top: 0;
  border-bottom-left-radius: 12rpx;
  border-bottom-right-radius: 12rpx;
  transform: translateX(-50%);
}

.ico-mic::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -20rpx;
  width: 4rpx;
  height: 10rpx;
  background: #25180f;
  transform: translateX(-50%);
  border-radius: 2rpx;
}

.ico-plus {
  border: 3rpx solid #25180f;
  border-radius: 50%;
}

.ico-plus::before,
.ico-plus::after {
  content: "";
  position: absolute;
  left: 50%;
  top: 50%;
  background: #25180f;
  transform: translate(-50%, -50%);
}

.ico-plus::before {
  width: 20rpx;
  height: 3rpx;
  border-radius: 2rpx;
}

.ico-plus::after {
  width: 3rpx;
  height: 20rpx;
  border-radius: 2rpx;
}

.map-chip-area {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  z-index: 70;
  pointer-events: none;
}

.action-chip-floating {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 62rpx;
  box-sizing: border-box;
  border-radius: 26rpx;
  border: 2rpx solid rgba(141, 104, 71, 0.2);
  background: rgba(255, 255, 255, 0.78);
  color: #3b2a1d;
  font-size: 34rpx;
  box-shadow: 0 8rpx 18rpx rgba(83, 56, 33, 0.12);
  pointer-events: auto;
}

.chip-map {
  width: 120rpx;
}

.chip-collect,
.chip-route,
.chip-qa {
  width: 156rpx;
}

.map-stage {
  position: relative;
}

.map-floor {
  height: 100%;
  border-radius: 22rpx;
  background:
    linear-gradient(160deg, rgba(255, 255, 255, 0.65), rgba(239, 226, 209, 0.76)),
    repeating-linear-gradient(
      to right,
      transparent 0rpx,
      transparent 64rpx,
      rgba(130, 96, 63, 0.06) 64rpx,
      rgba(130, 96, 63, 0.06) 66rpx
    );
  border: 2rpx solid rgba(150, 110, 73, 0.18);
  box-shadow: inset 0 20rpx 40rpx rgba(255, 255, 255, 0.4), 0 14rpx 34rpx rgba(101, 65, 35, 0.1);
  position: relative;
}

.split-map-stage {
  height: calc(100% - 76rpx);
}

.zone {
  position: absolute;
  border-radius: 18rpx;
  border: 2rpx dashed rgba(134, 95, 62, 0.45);
  font-size: 20rpx;
  color: #6e5035;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(246, 230, 210, 0.6);
}

.zone-a {
  background: rgba(231, 182, 122, 0.22);
}

.zone-active {
  border-color: #b54f2c;
  background: rgba(222, 118, 80, 0.3);
  color: #5f2414;
}

.zone-b {
  background: rgba(191, 150, 110, 0.2);
}

.zone-c {
  background: rgba(210, 176, 145, 0.2);
}

.user-dot {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: #d52f28;
  border: 4rpx solid #fff2e5;
  box-shadow: 0 0 0 10rpx rgba(213, 47, 40, 0.14);
  transform: translate(-50%, -50%);
  z-index: 10;
}

.control-row {
  margin-top: 16rpx;
  display: flex;
  gap: 12rpx;
}

.btn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 24rpx;
}

.ghost {
  border: 2rpx solid rgba(136, 99, 68, 0.24);
  background: rgba(255, 255, 255, 0.62);
  color: #5a3c20;
}

.explain-card {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 248rpx;
  background: rgba(255, 251, 245, 0.98);
  border-radius: 26rpx;
  border: 2rpx solid rgba(175, 123, 79, 0.22);
  box-shadow: 0 16rpx 40rpx rgba(81, 52, 27, 0.2);
  padding: 24rpx 26rpx;
  z-index: 96;
  transition: bottom 320ms ease;
}

.explain-card-split {
  bottom: 220rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #3c2918;
}

.card-desc {
  margin-top: 12rpx;
  color: #6b4d33;
  font-size: 26rpx;
  line-height: 1.7;
}

.card-foot {
  margin-top: 16rpx;
  display: flex;
  justify-content: space-between;
  font-size: 23rpx;
  color: #896547;
}

.close {
  color: #ba6d3a;
}
